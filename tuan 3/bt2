class SieuNhan:
    def __init__(self, ten, vu_khi, mau_sac):
        self.ten = ten
        self.vu_khi = vu_khi
        self.mau_sac = mau_sac

    def show(self):
        print(self.ten, self.vu_khi, self.mau_sac)

sn1 = SieuNhan("A", "Kiem", "Do")
sn2 = SieuNhan("B", "Sung", "Xanh")

sn1.show()
sn2.show()
